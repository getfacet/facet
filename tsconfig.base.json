{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@facet/core": ["packages/core/core/src/index.ts"],
      "@facet/runtime": ["packages/core/runtime/src/index.ts"],
      "@facet/runtime/node": ["packages/core/runtime/src/node.ts"],
      "@facet/react": ["packages/core/react/src/index.ts"],
      "@facet/agent-tools": ["packages/agent-stack/agent-tools/src/index.ts"],
      "@facet/reference-agent": ["packages/agent-stack/reference-agent/src/index.ts"],
      "@facet/quickstart": ["packages/agent-stack/quickstart/src/index.ts"],
      "@facet/agent": ["packages/extensions/agent/src/index.ts"],
      "@facet/agent-client": ["packages/extensions/agent-client/src/index.ts"],
      "@facet/client": ["packages/core/client/src/index.ts"],
      "@facet/assets": ["packages/core/assets/src/index.ts"],
      "@facet/cli": ["packages/extensions/cli/src/cli.ts"],
      "@facet/server": ["packages/core/server/src/index.ts"],
      "@facet/bridge": ["packages/extensions/bridge/src/index.ts"],
      "@facet/store-postgres": ["packages/extensions/store-postgres/src/index.ts"]
    }
  }
}
