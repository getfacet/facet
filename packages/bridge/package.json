{
  "name": "@facet/bridge",
  "version": "0.0.0",
  "description": "Local bridge — lets a local coding agent (Claude, Codex, …) own a Facet link from your machine, driving the page via the `facet` CLI.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "facet-bridge": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@facet/agent-client": "workspace:*",
    "@facet/cli": "workspace:*",
    "@facet/core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "facet-bridge": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
