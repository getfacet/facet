{
  "name": "@facet/bridge",
  "version": "0.0.0",
  "description": "Facet local bridge — lets a local coding agent own a Facet link from your machine via the `facet` CLI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getfacet/facet.git",
    "directory": "packages/extensions/bridge"
  },
  "homepage": "https://github.com/getfacet/facet#readme",
  "bugs": "https://github.com/getfacet/facet/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "sideEffects": false,
  "bin": {
    "facet-bridge": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.197",
    "@facet/agent": "workspace:*",
    "@facet/agent-client": "workspace:*",
    "@facet/cli": "workspace:*",
    "@facet/core": "workspace:*",
    "zod": "^4.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "facet-bridge": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
