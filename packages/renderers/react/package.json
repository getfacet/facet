{
  "name": "@facet/react",
  "version": "0.0.0",
  "description": "Facet React renderer — turns the declarative stage spec into a sandboxed component tree and applies patches live.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getfacet/facet.git",
    "directory": "packages/renderers/react"
  },
  "homepage": "https://github.com/getfacet/facet#readme",
  "bugs": "https://github.com/getfacet/facet/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "dependencies": {
    "@facet/assets": "workspace:*",
    "@facet/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}
