{
  "name": "@facet/ag-ui",
  "version": "0.0.0",
  "description": "Facet AG-UI adapter event conversion helpers and transports.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getfacet/facet.git",
    "directory": "packages/adapters/ag-ui"
  },
  "homepage": "https://github.com/getfacet/facet#readme",
  "bugs": "https://github.com/getfacet/facet/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "test": "cd ../../.. && vitest run packages/adapters/ag-ui/src/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/server.ts --format esm,cjs --dts --clean"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/core": "0.0.57",
    "@facet/core": "workspace:*",
    "@facet/runtime": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js",
        "require": "./dist/server.cjs"
      }
    }
  }
}
