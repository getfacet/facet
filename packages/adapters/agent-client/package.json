{
  "name": "@facet/agent-client",
  "version": "0.0.0",
  "description": "Facet reference agent-side client — dial into the reference server, receive visitor events, and drive the stage with heartbeat + reconnect.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getfacet/facet.git",
    "directory": "packages/adapters/agent-client"
  },
  "homepage": "https://github.com/getfacet/facet#readme",
  "bugs": "https://github.com/getfacet/facet/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "dependencies": {
    "@facet/core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}
