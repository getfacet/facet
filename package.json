{
  "name": "facet",
  "version": "0.0.0",
  "private": true,
  "description": "Interfaces your model draws — safe, live, per-user UI a language model renders itself.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "release": "pnpm build && changeset publish",
    "demo": "pnpm --filter @facet/playground demo"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "playwright": "^1.61.1",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.0"
  }
}
