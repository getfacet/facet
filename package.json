{
  "name": "facet",
  "version": "0.0.0",
  "private": true,
  "description": "Interfaces your model draws — safe, live, per-user UI a language model renders itself.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm build:packages && pnpm build:lab",
    "build:packages": "pnpm -r --filter \"./packages/*/*\" build",
    "build:lab": "pnpm --filter @facet/lab build",
    "verify": "pnpm typecheck && pnpm test && pnpm lint && pnpm format:check && pnpm build && node --test scripts/check-docs.test.mjs && node scripts/check-docs.mjs && node --test scripts/check-package-layout.test.mjs && node scripts/check-package-layout.mjs && node --test scripts/check-style-hard-cut.test.mjs && node scripts/check-style-hard-cut.mjs && node scripts/check-source-nuls.mjs",
    "package:smoke": "pnpm build:packages && node scripts/package-smoke.mjs",
    "release": "pnpm build:packages && changeset publish",
    "demo": "pnpm --filter @facet/playground demo"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "github-slugger": "^2.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.0"
  }
}
